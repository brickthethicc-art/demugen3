{
  "name": "@mugen/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate-framework": "pnpm --filter @mugen/server exec tsx ../../scripts/migrate-cards-to-framework.ts",
    "build:with-validation": "tsc --noEmit && pnpm run validate-framework"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
